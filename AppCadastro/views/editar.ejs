<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Editar Usuário</title>
    <style>
        body { font-family: sans-serif; max-width: 400px; margin: 20px auto; }
        input { width: 100%; margin-bottom: 10px; padding: 8px; }
        button { width: 100%; padding: 10px; background: #007bff; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>
    <h2>Editar Cadastro</h2>
    <form action="/atualizar/<%= user.id %>" method="POST">
        <input type="text" name="nome" value="<%= user.nome %>" required>
        <input type="text" name="cpf" value="<%= user.cpf %>">
        <fieldset>
            <legend>Endereço</legend>
            <input type="text" name="rua" value="<%= user.rua %>">
            <input type="text" name="numero" value="<%= user.numero %>">
            <input type="text" name="bairro" value="<%= user.bairro %>">
            <input type="text" name="cidade" value="<%= user.cidade %>">
        </fieldset>
        <fieldset>
            <legend>Plano</legend>
            <input type="text" name="plano" value="<%= user.plano %>">
            <input type="number" step="0.01" name="valor" value="<%= user.valor %>">
            <input type="text" name="velocidade" value="<%= user.velocidade %>">
        </fieldset>
        <button type="submit">Atualizar Dados</button>
        <p><a href="/usuarios">Cancelar</a></p>
    </form>
</body>
</html>
