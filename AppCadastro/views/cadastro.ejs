<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Cadastro de Cliente</title>
    <style>
        body { font-family: sans-serif; max-width: 400px; margin: 20px auto; }
        input, select { width: 100%; margin-bottom: 10px; padding: 8px; }
        button { width: 100%; padding: 10px; background: #28a745; color: white; border: none; }
    </style>
</head>
<body>
    <h2>Novo Cadastro</h2>
    <form action="/cadastrar" method="POST">
        <input type="text" name="nome" placeholder="Nome Completo" required>
        <input type="text" name="cpf" placeholder="CPF">
        <fieldset>
            <legend>Endereço</legend>
            <input type="text" name="rua" placeholder="Rua">
            <input type="text" name="numero" placeholder="Número">
            <input type="text" name="bairro" placeholder="Bairro">
            <input type="text" name="cidade" placeholder="Cidade">
        </fieldset>
        <fieldset>
            <legend>Plano</legend>
            <input type="text" name="plano" placeholder="Nome do Plano (Ex: Ouro)">
            <input type="number" step="0.01" name="valor" placeholder="Valor (Ex: 99.90)">
            <input type="text" name="velocidade" placeholder="Velocidade (Ex: 500 Mega)">
        </fieldset>
        <button type="submit">Salvar Cliente</button>
    </form>
</body>
</html>
